[
  {
    "name": "edge cases",
    "config": {
      "allow": [{"rule": "echo"}]
    },
    "cases": [
      {"input": "echo", "expect": "allow"},
      {
        "input": "$(echo)",
        "expect": "ask",
        "comment": "Contains two commands; first one's name is not static text, thus will never match."
      }
    ]
  },
  {
    "name": "redirects",
    "config": {
      "allow": [
        {"rule": "foo"},
        {"rule": "nope", "redirect": false},
        {"rule": "yep", "redirect": true}
      ],
      "deny": [
        {"rule": "foo2"},
        {"rule": "nope2", "redirect": false},
        {"rule": "yep2", "redirect": true}
      ]
    },
    "cases": [
      {"input": "foo", "expect": "allow"},
      {"input": "foo 2>&1", "expect": "allow"},
      {"input": "foo 2>&1 >/dev/null", "expect": "allow"},
      {"input": "foo 2>&3", "expect": "allow"},
      {"input": "foo > bar", "expect": "ask"},
      {"input": "foo > bar 2> /dev/null", "expect": "ask"},
      {"input": "foo < bar", "expect": "allow"},
      {"input": "foo <> bar", "expect": "ask"},
      {"input": "foo >> bar", "expect": "ask"},
      {"input": "foo >| bar", "expect": "ask"},
      {"input": "foo > /dev/null", "expect": "allow"},
      {"input": "foo 2> /dev/null", "expect": "allow"},
      {"input": "foo < /dev/urandom", "expect": "allow"},
      {"input": "foo <<EOF\ntest\nEOF", "expect": "allow"},
      {"input": "foo <<< 'hello'", "expect": "allow"},
      {"input": "nope", "expect": "allow"},
      {"input": "nope < /dev/urandom", "expect": "ask"},
      {"input": "yep > personal_notes.txt", "expect": "allow"},
      {"input": "foo2", "expect": "deny"},
      {"input": "foo2 > /dev/null", "expect": "deny"},
      {"input": "nope2", "expect": "deny"},
      {"input": "nope2 > test", "expect": "ask"},
      {"input": "yep2", "expect": "deny"},
      {"input": "yep2 > test", "expect": "deny"},
      {"input": "yep2 > /dev/null", "expect": "deny"}
    ]
  },
  {
    "name": "pipes",
    "config": {
      "allow": [
        {"rule": "foo"},
        {"rule": "outputter", "pipe": "out"},
        {"rule": "inputter", "pipe": "in"},
        {"rule": "nothing", "pipe": false}
      ],
      "deny": [
        {"rule": "foo2"},
        {"rule": "outputter2", "pipe": "out"},
        {"rule": "inputter2", "pipe": "in"},
        {"rule": "nothing2", "pipe": false}
      ]
    },
    "cases": [
      {"input": "foo", "expect": "allow"},
      {"input": "inputter", "expect": "allow"},
      {"input": "outputter", "expect": "allow"},
      {"input": "nothing", "expect": "allow"},
      {"input": "outputter | foo", "expect": "allow"},
      {"input": "foo | inputter", "expect": "allow"},
      {"input": "foo | outputter", "expect": "ask"},
      {"input": "inputter | foo", "expect": "ask"},
      {"input": "nothing | foo", "expect": "ask"},
      {"input": "foo | nothing", "expect": "ask"},
      {"input": "foo2", "expect": "deny"},
      {"input": "foo2 | foo", "expect": "deny"},
      {"input": "outputter2 | foo", "expect": "deny"},
      {"input": "foo | inputter2", "expect": "deny"},
      {"input": "nothing2 | foo", "expect": "ask"},
      {"input": "foo | foo; nothing; foo | foo && nothing", "expect": "allow"}
    ]
  },
  {
    "name": "nested evil command",
    "config": {
      "allow": [{"rule": "echo @arg*"}]
    },
    "cases": [
      {"input": "for d in /tmp/*; do echo \"$(evil $d)\"; ls \"$d\"; echo; done", "expect": "ask"},
      {"input": "echo <(evil)", "expect": "ask"},
      {"input": "{ evil; }", "expect": "ask"},
      {"input": "select x in a b; do evil; done", "expect": "ask"},
      {"input": "f() { evil; }; f", "expect": "ask"},
      {"input": "x=$(evil)", "expect": "ask"}
    ]
  },
  {
    "name": "git",
    "config": {
      "allow": [{"rule": "git @(-C @arg)? @{log,status,diff,show,blame} @arg*"}]
    },
    "cases": [
      {"input": "git log", "expect": "allow"},
      {"input": "git log mybranch", "expect": "allow"},
      {"input": "git log $mybranch", "expect": "ask"},
      {"input": "git log $(get-branch-name)", "expect": "ask"},
      {"input": "git -C . log", "expect": "allow"},
      {"input": "git rm", "expect": "ask"},
      {"input": "git -C . rm", "expect": "ask"}
    ]
  },
  {
    "name": "excepts",
    "config": {
      "allow": [
        {"rule": "echo @arg*", "unless": ["x"]},
        {"rule": "bar2 @arg*", "unless": ["x y", "z"]},
        {"rule": "bar3 @arg*", "unless": ["@{a,b}+"]}
      ]
    },
    "cases": [
      {"input": "echo foo", "expect": "allow"},
      {"input": "echo x", "expect": "ask"},
      {"input": "echo $var", "expect": "ask"},
      {"input": "echo ${var}", "expect": "ask"},
      {"input": "bar2 x", "expect": "allow"},
      {"input": "bar2 x y", "expect": "ask"},
      {"input": "bar2 x y z", "expect": "ask"},
      {"input": "bar2 z", "expect": "ask"},
      {"input": "bar3 x", "expect": "allow"},
      {"input": "bar3 a", "expect": "ask"},
      {"input": "bar3 a b", "expect": "ask"},
      {"input": "bar3 a b a", "expect": "ask"}
    ]
  },
  {
    "name": "flags",
    "config": {
      "allow": [
        {"rule": "c1 @arg*", "unless": ["-x"]},
        {"rule": "c2 @arg*", "unless": ["-foo"]},
        {"rule": "c3 @arg*", "unless": ["--bar"]},
        {"rule": "c4 @arg*"},
        {"rule": "c5 @arg* -x"}
      ],
      "deny": [
        {"rule": "c4 @arg* -x"}
      ]
    },
    "cases": [
      {"input": "c1 -", "expect": "allow"},
      {"input": "c1 --", "expect": "allow"},
      {"input": "c1 -x", "expect": "ask"},
      {"input": "c1 --x", "expect": "ask"},
      {"input": "c1 -xyz", "expect": "ask"},
      {"input": "c1 -xyz=123", "expect": "ask"},
      {"input": "c1 -xyz=", "expect": "ask"},
      {"input": "c1 -xyz 123", "expect": "ask"},
      {"input": "c1 -z", "expect": "allow"},
      {"input": "c2 -foo", "expect": "ask"},
      {"input": "c2 --foo", "expect": "ask"},
      {"input": "c2 --foo=123", "expect": "ask"},
      {"input": "c2 --foo=", "expect": "ask"},
      {"input": "c2 --foo 123", "expect": "ask"},
      {"input": "c2 -f", "expect": "allow"},
      {"input": "c2 -o", "expect": "allow"},
      {"input": "c3 --test", "expect": "allow"},
      {"input": "c3 --bar", "expect": "ask"},
      {"input": "c3 -bar", "expect": "ask"},
      {"input": "c3 -b", "expect": "allow"},
      {"input": "c4", "expect": "allow"},
      {"input": "c4 -x", "expect": "deny"},
      {"input": "c4 -xyz", "expect": "deny"},
      {"input": "c4 --xyz", "expect": "allow"},
      {"input": "c5 -x", "expect": "allow"},
      {"input": "c5 -xyz", "expect": "ask"},
      {"input": "c5 --xyz", "expect": "ask"}
    ]
  },
  {
    "name": "safe xargs (enabled)",
    "config": {
      "allow": [
        {"rule": "echo @arg*"},
        {"rule": "grep @arg+"},
        {"rule": "ls @arg*"}
      ]
    },
    "cases": [
      {"input": "echo foo | xargs grep", "expect": "allow"},
      {"input": "echo foo bar | xargs grep", "expect": "allow"},
      {"input": "echo foo | xargs ls", "expect": "allow"},
      {"input": "echo foo | xargs rm", "expect": "ask"},
      {"input": "echo foo | xargs -I{} grep", "expect": "ask"},
      {"input": "echo foo | xargs grep -r", "expect": "ask"},
      {"input": "echo | xargs grep", "expect": "ask"},
      {"input": "echo foo; xargs grep", "expect": "ask"},
      {"input": "echo foo | xargs grep > /dev/null", "expect": "allow"},
      {"input": "echo foo | xargs grep > evil.txt", "expect": "ask"},
      {"input": "echo foo | xargs", "expect": "ask"}
    ]
  },
  {
    "name": "safe xargs (disabled)",
    "config": {
      "allow": [
        {"rule": "echo @arg*"},
        {"rule": "grep @arg+"}
      ],
      "allowSafeXargs": false
    },
    "cases": [
      {"input": "echo foo | xargs grep", "expect": "ask"}
    ]
  }
]
